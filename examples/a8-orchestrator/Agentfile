version: 1
name: orchestrator
framework: langgraph
port: 8000
health_path: /health
health_timeout: 180
dockerfile: custom
volumes:
  - /data/sessions
  - /data/embeddings
  - /data/logs
env:
  - OPENAI_API_KEY
  - ORCHESTRATOR_MODE
services:
  chromadb:
    image: chromadb/chroma:0.4.24
    port: 8100
  postgres:
    image: postgres:16-alpine
    port: 5432
    volumes:
      - /var/lib/postgresql/data
    env:
      - POSTGRES_PASSWORD
      - POSTGRES_DB
  redis:
    image: redis:7-alpine
    port: 6379
security:
  no_new_privileges: true
  drop_capabilities:
    - NET_RAW
    - SYS_ADMIN
