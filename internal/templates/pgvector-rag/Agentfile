version: 1
name: {{.Name}}
framework: generic
port: 8000
health_path: /health
health_timeout: 120
dockerfile: auto
env:
  - OPENAI_API_KEY
  - OPENAI_BASE_URL
  - OPENAI_MODEL
services:
  postgres:
    image: pgvector/pgvector:pg17
    port: 5432
    env:
      POSTGRES_DB: ragdb
      POSTGRES_USER: rag
      POSTGRES_PASSWORD: ragpass
