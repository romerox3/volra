      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (rate(llm_request_cost_dollars_total{job=\"agent-metrics\"}[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
