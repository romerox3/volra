      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (type) (rate(llm_tokens_total{job=\"agent-metrics\"}[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
