      "description": "Application-reported metrics — all non-standard metrics exposed by the agent via prometheus_client",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "{job=\"agent-metrics\", __name__!~\"http_.*|process_.*|python_.*\"}",
          "legendFormat": "{{__name__}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
