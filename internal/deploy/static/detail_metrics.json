        "textMode": "auto"
      },
      "title": "Uptime (Probe, 24h)",
      "description": "Percentage of successful health probes in the last 24 hours",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg_over_time(probe_success{job=\"agent-health\"}[24h])",
          "legendFormat": "24h Uptime",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
