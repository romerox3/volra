# Generated by Volra — regenerate with: volra deploy
name: my-agent

services:
  agent:
    build:
      context: ..
      dockerfile: .volra/Dockerfile
    container_name: my-agent-agent
    restart: unless-stopped
    develop:
      watch:
        - action: rebuild
          path: ..
          ignore:
            - .volra/
            - __pycache__/
            - .git/
            - "*.pyc"
            - .venv/
            - venv/
            - .env
    ports:
      - "8000:8000"
    depends_on:
      my-agent-db:
        condition: service_started
      my-agent-redis:
        condition: service_started
    networks:
      - volra

  my-agent-db:
    image: postgres:16
    container_name: my-agent-db
    restart: unless-stopped
    ports:
      - "5432:5432"
    env_file:
      - ./my-agent-db.env
    volumes:
      - my-agent-db-var-lib-postgresql-data:/var/lib/postgresql/data
    networks:
      - volra

  my-agent-redis:
    image: redis:7-alpine
    container_name: my-agent-redis
    restart: unless-stopped
    networks:
      - volra
  blackbox:
    image: quay.io/prometheus/blackbox-exporter:v0.25.0
    container_name: my-agent-blackbox
    restart: unless-stopped
    volumes:
      - ./blackbox.yml:/config/blackbox.yml:ro
    command:
      - '--config.file=/config/blackbox.yml'
    networks:
      - volra

  prometheus:
    image: prom/prometheus:v3.1.0
    container_name: my-agent-prometheus
    restart: unless-stopped
    ports:
      - "9090:9090"
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./alert_rules.yml:/etc/prometheus/alert_rules.yml:ro
      - prometheus-data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.retention.time=7d'
      - '--storage.tsdb.retention.size=500MB'
    depends_on:
      - blackbox
    networks:
      - volra

  grafana:
    image: grafana/grafana-oss:12.4.0
    container_name: my-agent-grafana
    restart: unless-stopped
    ports:
      - "3001:3000"
    environment:
      - GF_AUTH_ANONYMOUS_ENABLED=true
      - GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
      - GF_AUTH_DISABLE_LOGIN_FORM=true
      - GF_DASHBOARDS_DEFAULT_HOME_DASHBOARD_PATH=/var/lib/grafana/dashboards/overview.json
    volumes:
      - ./grafana/dashboards:/var/lib/grafana/dashboards:ro
      - ./grafana/provisioning:/etc/grafana/provisioning:ro
    networks:
      - volra

volumes:
  prometheus-data:
  my-agent-db-var-lib-postgresql-data:

networks:
  volra:
    driver: bridge
