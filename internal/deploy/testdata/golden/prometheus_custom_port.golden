# Generated by Volra — regenerate with: volra deploy
global:
  scrape_interval: 15s
  scrape_timeout: 10s

rule_files:
  - /etc/prometheus/alert_rules.yml

scrape_configs:
  - job_name: agent-health
    metrics_path: /healthz
    static_configs:
      - targets:
          - agent:9000

  - job_name: agent-metrics
    metrics_path: /metrics
    static_configs:
      - targets:
          - agent:9000
