# Generated by Volra — regenerate with: volra deploy
name: {{.Name}}

services:
  agent:
    build:
      context: ..
{{- if eq (printf "%s" .Dockerfile) "custom"}}
      dockerfile: Dockerfile
{{- else}}
      dockerfile: .volra/Dockerfile
{{- end}}
    container_name: {{.Name}}-agent
    restart: unless-stopped
    develop:
      watch:
        - action: rebuild
          path: ..
          ignore:
            - .volra/
            - __pycache__/
            - .git/
            - "*.pyc"
            - .venv/
            - venv/
            - .env
{{- if .Env}}
    env_file:
      - ./agent.env
{{- end}}
{{- if .VolumeSpecs}}
    volumes:
{{- range .VolumeSpecs}}
      - {{.Name}}:{{.MountPath}}
{{- end}}
{{- end}}
{{- if .ServiceContexts}}
    depends_on:
{{- range .ServiceContexts}}
{{- if .Healthcheck}}
      {{$.Name}}-{{.Name}}:
        condition: service_healthy
{{- else}}
      {{$.Name}}-{{.Name}}:
        condition: service_started
{{- end}}
{{- end}}
{{- end}}
{{- if .Security}}
{{- if .Security.ReadOnly}}
    read_only: true
{{- end}}
{{- if .Security.NoNewPrivileges}}
    security_opt:
      - no-new-privileges:true
{{- end}}
{{- if .Security.DropCapabilities}}
    cap_drop:
{{- range .Security.DropCapabilities}}
      - {{.}}
{{- end}}
{{- end}}
{{- end}}
{{- if .SecurityTmpfs}}
    tmpfs:
{{- range .SecurityTmpfs}}
      - {{.Path}}:size={{if .Size}}{{.Size}}{{else}}100M{{end}}
{{- end}}
{{- end}}
{{- if .GPU}}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{{- end}}
    networks:
      - volra
{{range .ServiceContexts}}
  {{$.Name}}-{{.Name}}:
    image: {{.Image}}
    container_name: {{$.Name}}-{{.Name}}
    hostname: {{.Name}}
    restart: unless-stopped
{{- if gt .HostPort 0}}
    ports:
      - "{{.HostPort}}:{{.Port}}"
{{- end}}
{{- if .Env}}
    env_file:
      - ./{{$.Name}}-{{.Name}}.env
{{- end}}
{{- if .VolumeSpecs}}
    volumes:
{{- range .VolumeSpecs}}
      - {{.Name}}:{{.MountPath}}
{{- end}}
{{- end}}
{{- if .Healthcheck}}
    healthcheck:
      test: {{.Healthcheck.Test | toJSON}}
      interval: {{.Healthcheck.Interval}}
      timeout: {{.Healthcheck.Timeout}}
      retries: {{.Healthcheck.Retries}}
{{- if .Healthcheck.StartPeriod}}
      start_period: {{.Healthcheck.StartPeriod}}
{{- end}}
{{- end}}
{{- if .Resources}}
    deploy:
      resources:
        limits:
{{- if .Resources.MemLimit}}
          memory: {{.Resources.MemLimit}}
{{- end}}
{{- if .Resources.CPUs}}
          cpus: "{{.Resources.CPUs}}"
{{- end}}
{{- end}}
    networks:
      - volra
{{end}}  blackbox:
    image: quay.io/prometheus/blackbox-exporter:v0.25.0
    container_name: {{.Name}}-blackbox
    restart: unless-stopped
    volumes:
      - ./blackbox.yml:/config/blackbox.yml:ro
    command:
      - '--config.file=/config/blackbox.yml'
    networks:
      - volra

  prometheus:
    image: prom/prometheus:v3.1.0
    container_name: {{.Name}}-prometheus
    restart: unless-stopped
    ports:
      - "{{.PrometheusHostPort}}:9090"
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./alert_rules.yml:/etc/prometheus/alert_rules.yml:ro
      - prometheus-data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.retention.time=7d'
      - '--storage.tsdb.retention.size=500MB'
    depends_on:
      - blackbox
    networks:
      - volra

  grafana:
    image: grafana/grafana-oss:12.4.0
    container_name: {{.Name}}-grafana
    restart: unless-stopped
    ports:
      - "{{.GrafanaHostPort}}:3000"
    environment:
      - GF_AUTH_ANONYMOUS_ENABLED=true
      - GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
      - GF_AUTH_DISABLE_LOGIN_FORM=true
      - GF_DASHBOARDS_DEFAULT_HOME_DASHBOARD_PATH=/var/lib/grafana/dashboards/overview.json
    volumes:
      - ./grafana/dashboards:/var/lib/grafana/dashboards:ro
      - ./grafana/provisioning:/etc/grafana/provisioning:ro
    networks:
      - volra

  a2a-proxy:
    image: ghcr.io/romerox3/volra-proxy:{{.ProxyVersion}}
    container_name: {{.Name}}-a2a-proxy
    restart: unless-stopped
    ports:
      - "{{.AgentHostPort}}:80"
    environment:
      - VOLRA_AGENT_URL=http://agent:{{.Port}}
      - VOLRA_CARD_PATH=/etc/volra/agent-card.json
      - VOLRA_A2A_MODE={{.A2AMode}}
{{- if .A2ASkillsJSON}}
      - VOLRA_A2A_SKILLS={{.A2ASkillsJSON}}
{{- end}}
    volumes:
      - ./agent-card.json:/etc/volra/agent-card.json:ro
    depends_on:
      - agent
    networks:
      - volra
{{- if .Alerts}}

  alertmanager:
    image: prom/alertmanager:v0.27.0
    container_name: {{.Name}}-alertmanager
    restart: unless-stopped
    ports:
      - "{{.AlertmanagerHostPort}}:9093"
    volumes:
      - ./alertmanager.yml:/etc/alertmanager/alertmanager.yml:ro
    command:
      - '--config.file=/etc/alertmanager/alertmanager.yml'
    networks:
      - volra
{{- end}}

volumes:
  prometheus-data:
{{- range .VolumeSpecs}}
  {{.Name}}:
{{- end}}
{{- range .ServiceContexts}}
{{- range .VolumeSpecs}}
  {{.Name}}:
{{- end}}
{{- end}}

networks:
  volra:
    driver: bridge
