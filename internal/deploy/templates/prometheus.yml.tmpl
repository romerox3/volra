# Generated by Volra — regenerate with: volra deploy
global:
  scrape_interval: 15s
  scrape_timeout: 10s

rule_files:
  - /etc/prometheus/alert_rules.yml

scrape_configs:
  - job_name: {{.JobHealth}}
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
          - http://agent:{{.Port}}{{.HealthPath}}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox:9115

  - job_name: {{.JobMetrics}}
    metrics_path: /metrics
    static_configs:
      - targets:
          - agent:{{.Port}}
{{- if .HasLevel2}}

  - job_name: agent-level2
    metrics_path: /metrics
    scrape_interval: 15s
    static_configs:
      - targets:
          - agent:{{.ObservabilityMetricsPort}}
{{- end}}
