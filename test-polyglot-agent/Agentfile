# Polyglot Research Agent — Stress test for Volra
# Uses ALL Volra features simultaneously
version: 1

name: polyglot-agent
framework: generic
port: 8000
health_path: /health
host_port: 8080
dockerfile: auto

env:
  - OPENAI_API_KEY
  - ANTHROPIC_API_KEY
  - DATABASE_URL
  - REDIS_URL
  - CHROMA_HOST
  - CHROMA_PORT
  - LLM_PROVIDER

# 3 infrastructure services — each with healthchecks auto-resolved
services:
  redis:
    image: redis:7-alpine
    port: 6379
  postgres:
    image: postgres:16-alpine
    port: 5432
    volumes:
      - /var/lib/postgresql/data
    env:
      - POSTGRES_PASSWORD
  chromadb:
    image: chromadb/chroma:latest
    port: 8000
    host_port: 8001

# Security hardening — read_only triggers auto tmpfs
security:
  read_only: true
  no_new_privileges: true
  drop_capabilities:
    - NET_RAW
    - SYS_ADMIN

# Level 2 observability — full LLM metrics via volra-observe
observability:
  level: 2
  metrics_port: 9101

# Build-time setup: download NLTK data during Docker build
build:
  setup_commands:
    - "python -m nltk.downloader punkt punkt_tab"
  cache_dirs:
    - /root/nltk_data

# Persistent volumes for agent data
volumes:
  - /tmp/agent-cache

health_timeout: 120
